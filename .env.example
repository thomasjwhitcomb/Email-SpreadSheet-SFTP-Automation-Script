# --- Outlook credentials ---
OUTLOOK_EMAIL='your-outlook@domain.com'
# Password is stored in the OS keychain, not here.
# Run the app and go to Settings -> Outlook -> Set Password.

# --- Microsoft Graph API (for reminder emails via Azure AD) ---
# Register an app at portal.azure.com -> Azure Active Directory -> App registrations.
# Grant the app the "Mail.Send" Application permission and click "Grant admin consent".
#
# Application (client) ID  — shown on the app's Overview page
AZURE_CLIENT_ID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
# Client secret value  — required for the client credentials (application) flow
AZURE_CLIENT_SECRET='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
# Directory (tenant) ID  — use your org's tenant ID (GUID) or domain
AZURE_TENANT_ID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
# The mailbox that sends reminders — reuses OUTLOOK_EMAIL above.

# --- Atlas (atlas.heart.org) credentials ---
ATLAS_EMAIL='your-atlas@domain.com'
# Password is stored in the OS keychain, not here.
# Run the app and go to Settings -> Atlas -> Set Password.

# --- Organization name to filter classes by ---
ORGANIZATION_NAME='Your Org Name'

# --- Google Sheets ---
# Exact name of the Google Spreadsheet for AHA registrations
GOOGLE_SHEET_NAME='AHA Student Registration'

# Exact name of the Google Spreadsheet for Acuity appointments
ACUITY_GOOGLE_SHEET_NAME='RQI Registration Sheet'

# Path to the OAuth 2.0 client credentials JSON from Google Cloud Console.
# Steps to obtain:
#   1. Go to console.cloud.google.com -> APIs & Services -> Credentials
#   2. Click "Create Credentials" -> "OAuth client ID" -> "Desktop app"
#   3. Download the JSON and save it as 'credentials.json' in this folder.
# On first run a browser window opens for login; the token is cached as 'token.json'.
GOOGLE_CREDENTIALS_FILE=credentials.json

# --- Optional settings ---
# Browser engine: chromium, firefox, webkit  (default: chromium)
BROWSER='chromium'

# How many days back to search emails (default: 7)
EMAIL_LOOKBACK_DAYS='7'

# Run browser invisibly in the background (default: true - recommended)
HEADLESS='true'

# Set to 'true' during testing to skip all outbound emails (reminders + alerts).
# Acuity emails will still be parsed and logged to the RQI sheet normally.
TEST_MODE='false'

# Log intended mutations without sending email, writing sheets, accepting Atlas
# requests, or uploading to SFTP. Useful for training and parser validation.
DRY_RUN='false'

# --- Auto mode ---
# How often to scan for new emails, in seconds (default: 120)
SCAN_INTERVAL_SECONDS='120'

# --- Acuity Scheduling ---
ACUITY_SENDER_EMAIL='no-reply@acuityscheduling.com'

# --- SFTP / RQI Upload ---
SFTP_HOST='your-sftp-host.example.com'
SFTP_PORT='22'
SFTP_USERNAME='your-username'
SFTP_REMOTE_DIR='/uploads/your-dir'
SFTP_LOCAL_DIR='C:\temp'
SFTP_FILENAME='preprod_cl.csv'
RQI_DELTA_SHEET_NAME='RQI Upload Delta'

# Keyring service name for the SFTP password.
# One-time setup via the app: SFTP page -> Set Up Password.
SFTP_KEYRING_SERVICE='rqi-sftp'

# Optional upload verification
SFTP_VERIFY_SIZE=true
SFTP_VERIFY_SHA256=true
SFTP_AUTO_ADD_HOST_KEY=false

# --- Location door / keypad access codes ---
# These codes are sent to students in class-reminder emails.
# Store them here (gitignored) so they can be rotated without a code change.
BARTLETT_DOOR_CODE='0000'
BRENTWOOD_DOOR_CODE='0000'
CHAMBLEE_EXT_CODE='0000'
CHAMBLEE_OFFICE_CODE='0000'
DECATUR_DOOR_CODE='0000'
EXCHANGE_BLDG_CODE='0000'
EXCHANGE_OFFICE_CODE='0000'
MUSIC_DOOR_CODE='0000'
PERKINS_BLDG_CODE='0000'
PERKINS_SUITE_CODE='0000'
POPLAR_DOOR_CODE='0000'
SYCAMORE_DOOR_CODE='0000'

